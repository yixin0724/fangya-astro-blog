---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/common/PageHeader.astro";
import { favorites } from "../../data/mock";
---

<Layout
  title="所爱 | YiXin-加油！"
  description="记录我热爱的事情，以及那些长期吸引我的方向。"
>
  <main class="page-shell">
    <PageHeader eyebrow="热爱清单" title="所爱" description="不只是资源链接，而是那些真正让我投入时间、保持好奇和持续上头的事情。" />

    <section class="card-grid" aria-label="所爱内容分组">
      {
        favorites.map((group) => (
          <article class="resource-card">
            <h2>{group.group}</h2>
            <p>{group.description}</p>
            <ul class="resource-list">
              {group.items.map((item) => (
                <li>
                  <strong>{item.name}</strong>
                  <span>{item.description}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>
  </main>
</Layout>

<style>
  .resource-list {
    display: grid;
    gap: 16px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .resource-list li {
    display: grid;
    gap: 4px;
  }

  .resource-list strong {
    font-weight: 760;
  }

  .resource-list span {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }
</style>
