---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/common/PageHeader.astro";
import { siteConfig } from "../../site.config";
---

<Layout title="关于 | YiXin-加油！" description="关于我、技术兴趣和这个博客。">
  <main class="page-shell">
    <PageHeader eyebrow="个人介绍" title="关于" description="一些关于我、学习状态、科研方向和联系方式的信息。" />

    <section class="about-stack">
      <article class="plain-card about-card">
        <h2>关于我</h2>
        <p>
          你好，我是 YiXin，一名 2024 届软件工程专业硕士，目前在长理读研中，也是国防科大的联合培养生。
          现在主要研究 HPC 工作流调度相关优化，希望能在科研问题和工程实践之间找到稳定连接点。
        </p>

        <div class="about-lines" aria-label="个人信息">
          <div class="about-line">
            <strong>当前状态</strong>
            <span>长理读研中，国防科大联合培养生。</span>
          </div>
          <div class="about-line">
            <strong>科研方向</strong>
            <span>HPC 工作流调度相关优化。</span>
          </div>
          <div class="about-line">
            <strong>主要学习</strong>
            <span>后端开发为主，不过 Vibe Coding 的时代，应该基本都在向全栈发展吧。</span>
          </div>
          <div class="about-line">
            <strong>最喜欢</strong>
            <span>AI、大模型和深度学习。应该没有人不喜欢吧。</span>
          </div>
          <div class="about-line">
            <strong>游戏状态</strong>
            <span>LOL 爱好者，郊区大师的小菜 AD 和上单。</span>
          </div>
          <div class="about-line">
            <strong>长期状态</strong>
            <span>对新技术有强烈好奇心，沉迷学习技术无法自拔。学习使我快乐！(/doge)</span>
          </div>
        </div>
      </article>

      <section class="about-section" aria-labelledby="contact-title">
        <div class="section-header">
          <div>
            <h2 id="contact-title">联系</h2>
            <p>欢迎通过邮箱或 GitHub 交流技术、科研、AI Agent 或 LOL。</p>
          </div>
        </div>
        <div class="card-grid">
          <a class="plain-card" href="/about">
            <h3>位置</h3>
            <p>{siteConfig.location}</p>
          </a>
          <a class="plain-card" href={`mailto:${siteConfig.email}`}>
            <h3>邮箱</h3>
            <p>{siteConfig.email}</p>
          </a>
          <a class="plain-card" href={siteConfig.github} target="_blank" rel="noreferrer">
            <h3>GitHub</h3>
            <p>github.com/yixin0724</p>
          </a>
        </div>
      </section>
    </section>
  </main>
</Layout>

<style>
  .about-stack,
  .about-section {
    display: grid;
    gap: 52px;
  }

  .about-card p {
    max-width: 780px;
    margin-bottom: 0;
    font-size: 1.02rem;
  }

  .about-lines {
    display: grid;
    gap: 12px;
    margin-top: 28px;
  }

  .about-line {
    position: relative;
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: 20px;
    overflow: hidden;
    border: 1px solid var(--card-border);
    border-radius: 8px;
    padding: 18px 20px;
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(calc(var(--glass-blur) * 0.45)) saturate(120%);
    transition:
      border-color var(--duration-fast) ease,
      box-shadow var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-out);
  }

  .about-line::before {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 52%);
    opacity: 0;
    transition: opacity var(--duration-fast) ease;
    content: "";
    pointer-events: none;
  }

  .about-line:hover {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .about-line:hover::before {
    opacity: 1;
  }

  .about-line strong,
  .about-line span {
    position: relative;
    z-index: 1;
  }

  .about-line span {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 560px) {
    .about-line {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
